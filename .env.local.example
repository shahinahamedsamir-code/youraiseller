# TeamITQAN SMS (ccs.teamitqan.com) — platform gateway for all sellers
TEAMITQAN_SMS_API_KEY=your-sms-api-key
TEAMITQAN_SMS_SENDER_ID=880XXXXXXXXXX

# TeamITQAN Auto Call / MakeAudioCall (Space Tel) — REQUIRED, separate from SMS key
TEAMITQAN_AUDIO_API_KEY=your-makeaudiocall-api-key
TEAMITQAN_AUDIO_DID=09643331101
# TEAMITQAN_AUDIO_BASE_URL=https://ccs.teamitqan.com/api

# Public URL where production app runs — TeamITQAN fetches uploaded audio from here
# Bangladesh app subdomain (dashboard):
APP_URL=https://app.youraiseller.com
NEXT_PUBLIC_APP_URL=https://app.youraiseller.com
APP_HOST=app.youraiseller.com
MARKETING_HOST=youraiseller.com

# Local dev only — use ngrok URL here, NOT on live server
# NEXT_PUBLIC_APP_URL=https://your-subdomain.ngrok-free.dev

# Optional: when developing on localhost, auto-push uploaded audio to production server
# AUTO_CALL_AUDIO_SYNC_URL=https://youraiseller.com/api/auto-call/receive-audio
# AUTO_CALL_AUDIO_SYNC_SECRET=choose-a-long-random-secret

# Hoorin Order Guard — courier fraud / delivery ratio check (New Order)
HOORIN_API_KEY=your-hoorin-api-key
DEV_ADMIN_PASSWORD="your-secure-dev-password"

# Google OAuth (Console → APIs → Credentials → OAuth 2.0 Client ID → Web)
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://app.youraiseller.com
# Authorized redirect URIs: same origins (GIS uses popup, same origin)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
